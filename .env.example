# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/medical_trainer
REDIS_URL=redis://redis:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=48

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token
WEBAPP_URL=https://your-app.netlify.app
ALLOWED_ORIGINS=https://your-app.netlify.app,https://your-app.vercel.app
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Frontend (needed when building with Docker Compose) ───────────────────────
VITE_API_BASE=https://your-backend.onrender.com

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
